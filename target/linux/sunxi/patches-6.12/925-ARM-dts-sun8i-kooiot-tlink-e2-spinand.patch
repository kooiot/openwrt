--- a/arch/arm/boot/dts/allwinner/Makefile
+++ b/arch/arm/boot/dts/allwinner/Makefile
@@ -285,7 +285,8 @@ dtb-$(CONFIG_MACH_SUN8I) += \
 	sun8i-t113-tlink-dly-e204.dtb \
 	sun8i-t113-tlink-e1-v0.dtb \
	sun8i-t113-tlink-e1.dtb \
-	sun8i-t113-tlink-e2.dtb
+	sun8i-t113-tlink-e2.dtb \
+	sun8i-t113-tlink-e2-spinand.dtb
 dtb-$(CONFIG_MACH_SUN9I) += \
 	sun9i-a80-optimus.dtb \
 	sun9i-a80-cubieboard4.dtb
--- /dev/null
+++ b/arch/arm/boot/dts/allwinner/sun8i-t113-tlink-e2-spinand.dts
@@ -0,0 +1,41 @@
+// SPDX-License-Identifier: (GPL-2.0+ or MIT)
+// Copyright (C) 2026 Dirk Chang <dirk@kooiot.com>
+
+/dts-v1/;
+
+#include "sun8i-t113-tlink-e2.dts"
+
+/ {
+	model = "ThingsLink E2 (SPI-NAND)";
+	compatible = "kooiot,tlink-e2-spinand", "allwinner,sun8i-t113";
+
+	chosen {
+		bootargs = "root=/dev/fit0 rootwait";
+	};
+};
+
+&mmc2 {
+	status = "disabled";
+};
+
+&spi0 {
+	status = "okay";
+};
+
+&flash {
+	partitions {
+		compatible = "fixed-partitions";
+		#address-cells = <1>;
+		#size-cells = <1>;
+		boot@0 {
+			label = "boot";
+			reg = <0x0000000 0x0100000>;
+			read-only;
+		};
+
+		ubi0@100000 {
+			label = "ubi";
+			reg = <0x0100000 0x0000000>;
+		};
+	};
+};
