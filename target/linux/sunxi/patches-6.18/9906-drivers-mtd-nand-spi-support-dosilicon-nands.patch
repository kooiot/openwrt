+		     NAND_MEMORG(1, 2048, 128, 64, 2048, 40, 1, 1, 1),
+		     NAND_ECCREQ(8, 512),
+		     SPINAND_INFO_OP_VARIANTS(&ds_read_cache_variants, &ds_write_cache_variants, &ds_update_cache_variants),
+		     SPINAND_HAS_QE_BIT,
