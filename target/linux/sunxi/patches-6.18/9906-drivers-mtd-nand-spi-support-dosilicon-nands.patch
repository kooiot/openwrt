+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Dosilicon SPI NAND Flash driver for DS35 Series
+ * Support Full Models:
+ * 3.3V: DS35Q1GA/DS35Q2GA/DS35Q2GB/DS35Q2GBS/DS35Q4GB/DS35Q1GB/DS35Q2GD/DS35Q8GM
+ * 1.8V: DS35M1GA/DS35M2GA/DS35M2GB/DS35M2GBS/DS35M4GB/DS35M1GB/DS35M2GD/DS35M8GM
+ * Based on Dosilicon Official Datasheets & Linux MTD/SPINAND Framework
+ * Compatible with Linux Kernel 5.4 ~ 6.6+
+ */
+#include <linux/device.h>
+#include <linux/kernel.h>
+#include <linux/err.h>
+#include <linux/mtd/spinand.h>
+#include <linux/mtd/mtd.h>
+#include <linux/mtd/partitions.h>
+
+#define SPINAND_MFR_DOSILICON		0xE5
+
+#define DS_STATUS_ECC_NO_ERROR		(0 << 4)
+#define DS_STATUS_ECC_1_3BIT_CORR	(1 << 4)
+#define DS_STATUS_ECC_4_6BIT_CORR	(3 << 4)
+#define DS_STATUS_ECC_7_8BIT_CORR	(5 << 4)
+#define DS_STATUS_ECC_UNCOR_ERROR	(2 << 4)
+#define DS_ECC_STATUS_MASK		(7 << 4)
+
+static SPINAND_OP_VARIANTS(ds_read_cache_variants,
+		/* SPINAND_PAGE_READ_FROM_CACHE_1S_4S_4S_OP(0, 2, NULL, 0, 0), */
+		SPINAND_PAGE_READ_FROM_CACHE_1S_1S_4S_OP(0, 1, NULL, 0, 0),
+		/* SPINAND_PAGE_READ_FROM_CACHE_1S_2S_2S_OP(0, 1, NULL, 0, 0), */
+		SPINAND_PAGE_READ_FROM_CACHE_1S_1S_2S_OP(0, 1, NULL, 0, 0),
+		SPINAND_PAGE_READ_FROM_CACHE_FAST_1S_1S_1S_OP(0, 1, NULL, 0, 0),
+		SPINAND_PAGE_READ_FROM_CACHE_1S_1S_1S_OP(0, 1, NULL, 0, 0));
+
+static SPINAND_OP_VARIANTS(ds_write_cache_variants,
+		SPINAND_PROG_LOAD_1S_1S_4S_OP(true, 0, NULL, 0),
+		SPINAND_PROG_LOAD_1S_1S_1S_OP(true, 0, NULL, 0));
+
+static SPINAND_OP_VARIANTS(ds_update_cache_variants,
+		SPINAND_PROG_LOAD_1S_1S_4S_OP(true, 0, NULL, 0),
+		SPINAND_PROG_LOAD_1S_1S_1S_OP(true, 0, NULL, 0));
+		// SPINAND_PROG_LOAD_1S_1S_4S_OP(false, 0, NULL, 0), // 34/84 command won't update ECC when write FF
+		// SPINAND_PROG_LOAD_1S_1S_1S_OP(false, 0, NULL, 0));
+
+static int ds_ooblayout_64_ecc(struct mtd_info *mtd, int section, struct mtd_oob_region *region)
+{
+	if (section > 3)
+		return -ERANGE;
+	region->offset = (16 * section) + 8;
+	region->length = 8;
+	return 0;
+}
+
+static int ds_ooblayout_64_free(struct mtd_info *mtd, int section, struct mtd_oob_region *region)
+{
+	if (section > 3)
+		return -ERANGE;
+	section ? (region->offset = 16 * section, region->length = 8) :
+		(region->offset = 1, region->length = 7);
+	return 0;
+}
+
+static const struct mtd_ooblayout_ops ds_ooblayout_64_ops = {
+	.ecc = ds_ooblayout_64_ecc,
+	.free = ds_ooblayout_64_free,
+};
+
+static int ds_ooblayout_128_ecc(struct mtd_info *mtd, int section, struct mtd_oob_region *region)
+{
+	return section ? -ERANGE : ((region->offset = 64), (region->length = 64), 0);
+}
+
+static int ds_ooblayout_128_free(struct mtd_info *mtd, int section, struct mtd_oob_region *region)
+{
+	return section ? -ERANGE : ((region->offset = 1), (region->length = 63), 0);
+}
+
+static const struct mtd_ooblayout_ops ds_ooblayout_128_ops = {
+	.ecc = ds_ooblayout_128_ecc,
+	.free = ds_ooblayout_128_free,
+};
+
+static int ds_ecc_4bit_get_status(struct spinand_device *spinand, u8 status)
+{
+	switch (status & DS_ECC_STATUS_MASK) {
+	case DS_STATUS_ECC_NO_ERROR:
+		return 0;
+	case DS_STATUS_ECC_1_3BIT_CORR:
+		return 4;
+	case DS_STATUS_ECC_UNCOR_ERROR:
+		return -EBADMSG;
+	default:
+		return -EINVAL;
+	}
+}
+
+static int ds_ecc_8bit_gbs_get_status(struct spinand_device *spinand, u8 status)
+{
+	switch (status & DS_ECC_STATUS_MASK) {
+	case 0x00 << 4: return 0;
+	case 0x01 << 4: return 3;
+	case 0x03 << 4: return 6;
+	case 0x05 << 4: return 8;
+	case 0x02 << 4: return -EBADMSG;
+	default: return -EINVAL;
+	}
+}
+#if 0
+static int dosilicon_spinand_detect(struct spinand_device *spinand)
+{
+	u8 id[2] = {0};
+	int ret = spinand_read_id(spinand, id, sizeof(id));
+
+	if (ret) {
+		dev_err(&spinand->dev, "Dosilicon: Read ID failed, ret=%d\n", ret);
+		return ret;
+	}
+	if (id[0] != SPINAND_MFR_DOSILICON) {
+		dev_err(&spinand->dev, "Dosilicon: Invalid MFR ID[0x%02x], expect 0x%02x\n", id[0], SPINAND_MFR_DOSILICON);
+		return -ENODEV;
+	}
+	return 0;
+}
+#endif
